{
  "permissions": {
    "allow": [
      "Shell(ls)"
    ],
    "deny": []
  },
  "editor": {
    "vimMode": false
  },
  "display": {
    "showLineNumbers": true,
    "showThinkingBlocks": false,
    "showStatusIndicators": false
  },
  "notifications": true,
  "hints": true,
  "rewind": false,
  "suggestNextPrompt": false,
  "model": {
    "modelId": "default",
    "displayModelId": "auto",
    "displayName": "Auto",
    "displayNameShort": "Auto",
    "aliases": [
      "auto"
    ],
    "maxMode": false
  },
  "maxMode": false,
  "modelParameters": {
    "default": []
  },
  "selectedModel": {
    "modelId": "default",
    "parameters": []
  },
  "network": {
    "useHttp1ForAgent": false
  },
  "approvalMode": "allowlist",
  "sandbox": {
    "mode": "disabled",
    "networkAccess": "user_config_with_defaults"
  },
  "attribution": {
    "attributeCommitsToAgent": true,
    "attributePRsToAgent": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.cursor/statusline.sh",
    "padding": 1,
    "updateIntervalMs": 500,
    "timeoutMs": 1500
  }
}

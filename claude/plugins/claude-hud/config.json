    "showConfigCounts": true,
    "showTokenBreakdown": true,
    "showUsage": true,
    "usageBarEnabled": true,
    "showTools": true,
    "showAgents": true,
    "showTodos": true,
    "showSpeed": true,
    "showDuration": true,
    "showSessionName": true,
    "autocompactBuffer": "enabled",

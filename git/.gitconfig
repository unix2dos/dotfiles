# ============================================================================
# 一、用户身份配置
# ============================================================================
# 配置 Git 用户信息、凭证管理和条件配置加载
# 支持为不同目录设置不同的用户身份（个人 vs 工作）
# ----------------------------------------------------------------------------

[user]
	name = unix2dos
	email = levonfly@gmail.com

[credential]
	# 将凭证存储在磁盘上，避免每次推送/拉取时重复输入密码
	helper = store

[includeIf "gitdir/i:~/go/src/"]
	# 会覆盖上面的 user.name 和 user.email
	path = ~/.gitconfig-work


# ============================================================================
# 二、核心功能配置
# ============================================================================
# Git 的基础行为设置，包括字符编码、文件忽略、初始化等
# ----------------------------------------------------------------------------

[core]
	# 不对非 ASCII 字符进行转义，正确显示中文文件名和路径
	quotepath = false

	# 全局分页器美化
	pager = diff-so-fancy | less --tabs=4 -RF
	#pager = delta

	# 全局忽略文件配置（IDE 配置、系统文件等）
	excludesfile = /Users/liuwei/workspace/LevonConfig/Config/git/ignore

[init]
	defaultBranch = main

[pull]
	rebase = false


# ============================================================================
# 三、显示与美化
# ============================================================================
# 命令别名、日志美化、差异显示优化
# ----------------------------------------------------------------------------

[alias]
	# lg: 美化的 Git 日志视图
	# 显示：提交时间（绿色）+ Hash（黄色）+ 分支（红色）+ 提交信息 + 作者（蓝色）
	# 用法：git lg 或 git lg -10（显示最近 10 条）
	lg = log --color --graph --pretty=format:'%Cgreen(%cd)%Creset %C(yellow)%h%Creset -%C(red)%d%Creset %s %C(bold blue)<%an>%Creset' --abbrev-commit --date=format:'%Y-%m-%d %H:%M'

[diff-so-fancy]
	markEmptyLines = false
	changeHunkIndicators = false # 文件修改头之类
	#stripLeadingSymbols = false  # + 和 -

[delta]
    navigate = true  # use n and N to move between diff sections
	side-by-side = true
	line-numbers = true
	hyperlinks = true


[interactive]
	# 交互式命令（如 git add -p）
	diffFilter = diff-so-fancy --patch
	#diffFilter = delta --color-only


# ============================================================================
# 四、网络与传输
# ============================================================================
# HTTP 配置、URL 重写规则（HTTPS 转 SSH）
# ----------------------------------------------------------------------------

[http]
	# 较大的 HTTP 缓冲区（约 500MB），用于处理大文件推送/拉取
	postBuffer = 524288000



# ============================================================================
# 五、扩展功能
# ============================================================================
# Git LFS（大文件存储）配置
# ----------------------------------------------------------------------------

[filter "lfs"]
	# Git LFS 进程过滤器
	process = git-lfs filter-process
	required = true
	# 清理过滤器：将大文件转换为指针文件
	clean = git-lfs clean -- %f
	# 涂抹过滤器：检出时将指针文件还原为实际文件
	smudge = git-lfs smudge -- %f
